<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>
    <%= title %>
  </title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #0f1117;
      color: #e2e8f0;
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .header {
      background: #1e293b;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid #334155;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .header h1 {
      font-size: 1.2rem;
      color: #7c3aed;
    }

    .note {
      font-size: 0.78rem;
      color: #64748b;
    }

    .layout {
      display: flex;
      flex: 1;
      overflow: hidden;
    }

    .sidebar {
      width: 200px;
      background: #1e293b;
      border-right: 1px solid #334155;
      padding: 1rem;
      overflow-y: auto;
    }

    .sidebar h3 {
      font-size: 0.8rem;
      color: #64748b;
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }

    #userList div {
      font-size: 0.85rem;
      padding: 0.3rem 0;
      color: #94a3b8;
    }

    #userList div::before {
      content: '🟢 ';
    }

    .chat-area {
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    #messages {
      flex: 1;
      overflow-y: auto;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .msg {
      background: #1e293b;
      border-radius: 8px;
      padding: 0.6rem 1rem;
      max-width: 75%;
    }

    .msg .meta {
      font-size: 0.72rem;
      color: #64748b;
      margin-bottom: 0.2rem;
    }

    .msg .text {
      font-size: 0.9rem;
    }

    .msg.own {
      background: #4c1d95;
      align-self: flex-end;
    }

    .system-msg {
      text-align: center;
      font-size: 0.78rem;
      color: #64748b;
      padding: 0.25rem;
    }

    .typing-indicator {
      padding: 0.4rem 1rem;
      font-size: 0.78rem;
      color: #64748b;
      min-height: 1.5rem;
    }

    .input-area {
      padding: 1rem;
      border-top: 1px solid #334155;
      display: flex;
      gap: 0.5rem;
    }

    #msgInput {
      flex: 1;
      background: #1e293b;
      border: 1px solid #334155;
      color: #e2e8f0;
      padding: 0.6rem 1rem;
      border-radius: 8px;
      font-size: 0.9rem;
      outline: none;
    }

    #msgInput:focus {
      border-color: #7c3aed;
    }

    button {
      background: #7c3aed;
      color: white;
      border: none;
      padding: 0.6rem 1.2rem;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.9rem;
    }

    button:hover {
      background: #6d28d9;
    }
  </style>
</head>

<body>

  <div class="header">
    <h1>💬 Live Chat</h1>
    <div style="display: flex; align-items: center; gap: 1rem;">
      <span class="note">Connected as: <strong id="myName">
          <%= username %>
        </strong></span>
      <a href="/auth/logout"
        style="background: #ef4444; color: white; padding: 0.4rem 0.8rem; border-radius: 6px; text-decoration: none; font-size: 0.8rem; font-weight: bold;">Logout</a>
    </div>
  </div>

  <div class="layout">
    <div class="sidebar">
      <h3>🟢 Online</h3>
      <div id="userList"></div>
    </div>

    <div class="chat-area">
      <div id="messages"></div>
      <div class="typing-indicator" id="typingIndicator"></div>
      <div class="input-area" style="flex-direction: column;">
        <div
          style="display: flex; gap: 0.5rem; align-items: center; border-bottom: 1px solid #334155; padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
          <span style="color:#94a3b8; font-size:0.85rem">Send to:</span>
          <select id="userSelect"
            style="background:#1e293b; color:white; border:1px solid #334155; border-radius:4px; padding:0.3rem;">
            <option value="general">General Chat</option>
          </select>
          <span style="color:#94a3b8; font-size:0.85rem; margin-left: 1rem;">Attach log:</span>
          <input type="file" id="logFile" accept=".txt" style="color:#e2e8f0; font-size:0.8rem;" />
          <button onclick="analyzeAndSend()"
            style="background:#4c1d95; padding:0.4rem 0.8rem; font-size:0.8rem;">Analyze & Send</button>
        </div>
        <div style="display: flex; gap: 0.5rem; width: 100%;">
          <input id="msgInput" type="text" placeholder="Type a message... (Enter to send)" autocomplete="off"
            style="flex: 1;" />
          <button onclick="sendMessage()">Send</button>
        </div>
      </div>
    </div>
  </div>

  <!-- CONCEPT 8: Socket.io client library (served automatically by socket.io server) -->
  <script src="/socket.io/socket.io.js"></script>
  <script>
    const myUsername = '<%= username %>';

    // ── Connect to Socket.io server ──────────────────────────────────────────
    // This creates a PERSISTENT full-duplex WebSocket connection
    const socket = io();

    // ── Announce our username once connected ─────────────────────────────────
    socket.on('connect', () => {
      addSystemMsg('✅ Connected to server (WebSocket)');
      socket.emit('user:join', myUsername);    // Emit to server
    });

    // ── Listen: new chat message ─────────────────────────────────────────────
    socket.on('chat:message', (msg) => {
      const isOwn = msg.username === myUsername;
      const div = document.createElement('div');
      div.className = 'msg' + (isOwn ? ' own' : '');
      div.innerHTML = `
      <div class="meta">${msg.isPrivate ? '🔒 DM ' : ''}${msg.username} ${msg.to && !isOwn ? '→ ' + msg.to : ''} · ${new Date(msg.timestamp).toLocaleTimeString()}</div>
      <div class="text" style="white-space: pre-wrap;">${escapeHtml(msg.text)}</div>
    `;
      document.getElementById('messages').appendChild(div);
      scrollToBottom();
    });

    // ── Listen: online users list updated ────────────────────────────────────
    socket.on('user:online', (data) => {
      const list = document.getElementById('userList');
      list.innerHTML = data.users.map(u => `<div>${escapeHtml(u)}</div>`).join('');

      const select = document.getElementById('userSelect');
      if (select) {
        const currentVal = select.value;
        select.innerHTML = '<option value="general">General Chat</option>' +
          data.users.filter(u => u !== myUsername).map(u => `<option value="${escapeHtml(u)}">${escapeHtml(u)}</option>`).join('');
        if ([...select.options].some(o => o.value === currentVal)) {
          select.value = currentVal;
        }
      }

      addSystemMsg(data.message);
    });

    // ── Listen: typing indicator ─────────────────────────────────────────────
    socket.on('typing:indicator', (data) => {
      const el = document.getElementById('typingIndicator');
      el.textContent = data.typing ? `✏️ ${data.username} is typing...` : '';
    });

    // ── Listen: disconnect ───────────────────────────────────────────────────
    socket.on('disconnect', () => {
      addSystemMsg('❌ Disconnected from server');
    });

    // ── Send message ─────────────────────────────────────────────────────────
    function sendMessage() {
      const input = document.getElementById('msgInput');
      const text = input.value.trim();
      if (!text) return;

      const to = document.getElementById('userSelect').value;
      if (to === 'general') {
        socket.emit('chat:message', { text });
      } else {
        socket.emit('chat:private', { text, toUsername: to });
      }

      socket.emit('typing:stop');
      input.value = '';
    }

    // ── Analyze And Send ─────────────────────────────────────────────────────
    async function analyzeAndSend() {
      const fileInput = document.getElementById('logFile');
      if (!fileInput.files.length) return alert('Please select a .txt chat log file first.');

      const formData = new FormData();
      formData.append('file', fileInput.files[0]);

      addSystemMsg('⏳ Analyzing file...');
      try {
        const res = await fetch('/api/analyze', { method: 'POST', body: formData });
        const data = await res.json();

        if (data.success) {
          const report = `📊 CHAT ANALYSIS REPORT\nTotal Messages: ${data.totalMessages}\nTotal Users: ${data.totalUsers}\nMost Active: ${data.mostActiveUser}\nSentiment: ${data.sentimentBreakdown.positive}% Pos, ${data.sentimentBreakdown.negative}% Neg\nTop Words: ${data.topWords.join(', ')}`;

          const to = document.getElementById('userSelect').value;
          if (to === 'general') {
            socket.emit('chat:message', { text: report });
          } else {
            socket.emit('chat:private', { text: report, toUsername: to });
          }
          fileInput.value = '';
          addSystemMsg('✅ Report sent!');
        } else {
          alert('Error: ' + data.message);
        }
      } catch (e) {
        alert('Analysis failed: ' + e.message);
      }
    }

    // ── Typing detection ─────────────────────────────────────────────────────
    let typingTimer;
    document.getElementById('msgInput').addEventListener('input', () => {
      socket.emit('typing:start');
      clearTimeout(typingTimer);
      typingTimer = setTimeout(() => socket.emit('typing:stop'), 1500);
    });

    // ── Enter key shortcut ───────────────────────────────────────────────────
    document.getElementById('msgInput').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') sendMessage();
    });

    // ── Helpers ──────────────────────────────────────────────────────────────
    function addSystemMsg(text) {
      const div = document.createElement('div');
      div.className = 'system-msg';
      div.textContent = text;
      document.getElementById('messages').appendChild(div);
      scrollToBottom();
    }

    function scrollToBottom() {
      const msgs = document.getElementById('messages');
      msgs.scrollTop = msgs.scrollHeight;
    }

    function escapeHtml(text) {
      return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }
  </script>
</body>

</html>